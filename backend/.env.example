# Database Configuration
MONGODB_URI=mongodb://localhost:27017/loadgate
MONGODB_NAME=loadgate

# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Arduino Configuration
ARDUINO_PORT=COM3
ARDUINO_BAUDRATE=9600

# Camera Configuration
CAMERA_URL=http://camera-ip-address:port/stream
CAMERA_USERNAME=admin
CAMERA_PASSWORD=password

# Image Storage
STORAGE_PATH=./public/uploads
MAX_FILE_SIZE=10485760

# FFmpeg Configuration
FFMPEG_PATH=ffmpeg

# IR Sensor Configuration
IR_EVENT_TIMEOUT=5000
IR_DEBOUNCE_TIME=500

# Weight Settings
MAX_WEIGHT_LIMIT=5000
WEIGHT_CALIBRATION=1.0

# API Keys (Optional)
GOOGLE_GEMINI_API_KEY=your_api_key_here

# Logging
LOG_LEVEL=info
LOG_PATH=./logs

# Mailer Configuration (Optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
